# ── Model Configuration ──────────────────────────────────────────────
# Path to the jersey-number YOLO model (100-class: numbers 0-99)
YOLO_MODEL_SOURCE=app/model/jersey_number_yolo11m.pt

# Path to person-detection / segmentation model (COCO person class)
# Use a *-seg.pt variant for segmentation masks (recommended).
# `yolo26n-seg.pt` auto-downloads through Ultralytics on first run if not cached yet.
PERSON_MODEL_SOURCE=yolo26n-seg.pt

# Device for YOLO inference: "auto", "cpu", "cuda", "mps", or "0"/"1" for GPU index
YOLO_DEVICE=auto

# Jersey reader backend:
# - "public_reader_ensemble" -> Grad ViT-B primary + Koshkina legibility/PARSeq fallback
# - "legacy_yolo" -> existing YOLO-only number reader
JERSEY_READER_BACKEND=public_reader_ensemble

# Allow automatic fallback to the legacy YOLO reader if public checkpoints are unavailable.
PUBLIC_READER_ALLOW_LEGACY_FALLBACK=true

# Optional auto-download for public checkpoints via gdown.
PUBLIC_READER_AUTO_DOWNLOAD=false

# Local checkout locations for the public research repos.
# These directories are gitignored; use `python scripts/bootstrap_public_reader.py`
# to recreate them on a fresh clone.
PUBLIC_READER_REPO_DIR=external/uncertainty-jnr
PARSEQ_REPO_DIR=external/jersey-number-pipeline/str/parseq

# Directory used to store downloaded or manually placed public weights.
# This directory is gitignored so public checkpoints do not get pushed.
PUBLIC_MODELS_DIR=app/model/public

# Grad uncertainty-aware reader (primary model).
GRAD_CHECKPOINT_PATH=app/model/public/uncertainty_jnr_vitb.pth
GRAD_CONFIG_PATH=external/uncertainty-jnr/configs/base8_reid.yaml
GRAD_MIN_CONFIDENCE=0.60
GRAD_MAX_UNCERTAINTY=0.25

# Koshkina fallback stack.
LEGIBILITY_MODEL_PATH=app/model/public/koshkina_legibility_soccer.pth
LEGIBILITY_THRESHOLD=0.50
PARSEQ_CHECKPOINT_PATH=app/model/public/koshkina_parseq_soccer.ckpt
PARSEQ_USE_PRETRAINED_FALLBACK=true
PARSEQ_MIN_CONFIDENCE=0.55

# ── Pipeline Strategy ───────────────────────────────────────────────
# "detection_first" (recommended) — person detect → color filter → number model
# "color_first" — HSV color mask → contour ROIs → number model
DETECTION_STRATEGY=detection_first

# ── Frame Extraction ────────────────────────────────────────────────
# Frames per second to sample from the video
FPS=2

# Maximum frames to process (comment out for no limit)
# MAX_FRAMES=120

# Frames per processing batch
FRAME_BATCH_SIZE=50

# Number of CPU workers for parallel preprocessing
PIPELINE_WORKERS=4

# ── Confidence Thresholds ───────────────────────────────────────────
# Minimum YOLO confidence for raw detections (person + jersey models)
DETECTOR_CONF_THRESHOLD=0.35

# Internal pipeline threshold — candidates below this are discarded
CONF_THRESHOLD_INTERNAL=0.55

# Export threshold — only detections above this are returned to the caller
CONF_THRESHOLD_EXPORT=0.55

# YOLO NMS IOU threshold
DETECTOR_IOU_THRESHOLD=0.45

# ── Color Filtering ─────────────────────────────────────────────────
# HSV hue tolerance (±degrees) for single-point colour matching fallback
HSV_TOLERANCE_H=20

# HSV saturation/value tolerance for single-point fallback
HSV_TOLERANCE_SV=60

# ── Person Detection ────────────────────────────────────────────────
# Minimum person crop height (px) — smaller persons are skipped
MIN_PERSON_CROP_HEIGHT=80

# Minimum confidence for person-class detections
PERSON_FALLBACK_MIN_CONF=0.35

# Enable person-overlap fallback scoring
ENABLE_PERSON_FALLBACK=true

# ── Position Prior ──────────────────────────────────────────────────
# Weight of position-based prior in final confidence blend (0.0–1.0)
POSITION_PRIOR_WEIGHT=0.10

# ── Browser / CORS ──────────────────────────────────────────────────
# Comma-separated origins allowed to call the API directly from browsers.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOW_METHODS=GET,POST,OPTIONS
# CORS_ALLOW_HEADERS=*

# ── Temporal Intelligence ───────────────────────────────────────────
# Frame similarity threshold (0–1); frames above this are skipped as duplicates
SKIP_SIMILARITY_THRESHOLD=0.97

# Consecutive confident detections to trigger early exit (0 = disabled)
EARLY_EXIT_CONSECUTIVE=0

# ── YouTube Download ────────────────────────────────────────────────
# Maximum seconds of video to download from YouTube.
# Leave unset to download the full source video.
# YOUTUBE_CLIP_SECONDS=120

# Paths to yt-dlp and ffmpeg binaries (auto-detected if on PATH)
# YT_DLP_BINARY=yt-dlp
# FFMPEG_BINARY=ffmpeg
# FFPROBE_BINARY=ffprobe

# JS runtime for yt-dlp (needed for YouTube extraction)
YT_DLP_JS_RUNTIMES=deno

# ── ROI Extraction (color-first strategy) ───────────────────────────
ROI_MIN_AREA=350
ROI_PADDING_PX=8
ROI_MAX_AREA_RATIO=0.55
MAX_ROIS_PER_FRAME=12

# ── Debug ───────────────────────────────────────────────────────────
# Set to a file path to produce an annotated debug video
# DEBUG_VIDEO_PATH=debug_output.mp4

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Server ──────────────────────────────────────────────────────────
PORT=8000
